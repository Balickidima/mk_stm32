{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m4",
    "extra_flags": [
      "-DSTM32F401",
      "-DSTM32F401xC"
    ],
    "f_cpu": "84000000L",
    "mcu": "STM32F401CCUx",
    "product_line": "STM32F401",
    "variant": "STM32F401"
  },
  "debug": {
    "jlink_device": "STM32F401CC",
    "openocd_target": "stm32f4x.cfg",
    "openocd_work_area": 16384
  },
  "frameworks": [
    "cmsis",
    "stm32cube"
  ],
  "name": "STM32F401CCUx",
  "upload": {
    "maximum_ram_size": 65536,
    "maximum_size": 262144,
    "protocol": "stlink",
    "protocols": [
      "stlink",
      "jlink",
      "blackmagic"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32.html",
  "vendor": "STMicroelectronics"
}
